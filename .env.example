APP_NAME="Smart Sourcing Academy"
BRAND_NAME="Smart Sourcing Academy"
BRAND_SHORT_NAME="SSU Academy"
BRAND_AUTHOR="Smart Sourcing USA"
BRAND_TAGLINE="Enterprise training for teams and professionals within the construction industry."
LEGAL_AGREEMENT_VERSION=2026-07-16

# Local development defaults (change for UAT/staging/production)
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# UAT / staging / production — use these instead of the values above:
# APP_ENV=staging
# APP_DEBUG=false
# APP_URL=https://academy-uat.example.com

# Used for password-reset links and payment return URLs (usually same as APP_URL)
FRONTEND_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ssu_academy
DB_USERNAME=root
DB_PASSWORD=
# Leave empty on first upgrade from legacy unprefixed tables, run:
#   php artisan ssu:migrate-table-prefix
# Then set:
DB_TABLE_PREFIX=ssu_academy_

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@ssu-academy.local"
MAIL_FROM_NAME="${APP_NAME}"

# UAT: configure real SMTP before testing forgot-password / email verification.
# Local option: Mailpit/Mailhog on 127.0.0.1:1025 (see MAIL_HOST/PORT above).

STRIPE_TEST_MODE=true
STRIPE_SYNC_FROM_ENV=true

# Subscription billing (required for cancel/resubscribe webhooks locally — use Stripe CLI)
# stripe listen --forward-to localhost:8000/stripe/webhook
STRIPE_WEBHOOK_SECRET=
SUBSCRIPTION_GRACE_DAYS=3
SUBSCRIPTION_PORTAL_RETURN_URL=http://localhost:8000/dashboard/external/subscriptions

# Comma-separated domains that auto-register as internal employees (free course access)
EMPLOYEE_EMAIL_DOMAINS=smartsourcingusa.com

# Set by the web installer after first-time setup (1 = installed, installer routes locked)
SSU_ACADEMY_INSTALLED=

# Staging/UAT only: show test account shortcuts on the login page
# SSU_SHOW_TEST_ACCOUNTS=true

# --- UAT deploy steps (after copying this file to .env) ---
# 1. php artisan key:generate
# 2. Set DB_* credentials
# 3. php artisan migrate --force
# 4. php artisan storage:link
# 5. npm ci && npm run build
# 6. Create UAT users in admin (do not use local test passwords on shared servers)
# See TESTING_GUIDE.md for full UAT scenarios and account setup.
