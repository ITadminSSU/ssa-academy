# Copy this file to .env on Hostinger after upload.
# Replace ALL placeholder values marked with CHANGE_ME.

APP_NAME="SSU Academy UAT"
BRAND_NAME="Smart Sourcing Academy"
BRAND_SHORT_NAME="SSU Academy"
BRAND_AUTHOR="Smart Sourcing USA"
BRAND_TAGLINE="Enterprise training for teams and professionals within the construction industry."

APP_ENV=staging
APP_DEBUG=false
APP_KEY=CHANGE_ME_COPY_FROM_LOCAL_ENV
APP_URL=https://CHANGE_ME.hostingersite.com
FRONTEND_URL=https://CHANGE_ME.hostingersite.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=CHANGE_ME
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_TABLE_PREFIX=ssu_academy_

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Public file URLs on Hostinger (no PHP symlink)
# Use app/public when media URLs must be /storage/app/public/... (common on Hostinger).
# Leave empty only if your URLs are /storage/filename.jpg with no extra segment.
PUBLIC_STORAGE_PATH=app/public

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@smartsourcingusa.com"
MAIL_FROM_NAME="${APP_NAME}"

EMPLOYEE_EMAIL_DOMAINS=smartsourcingusa.com
SSU_ACADEMY_INSTALLED=1

# Show login shortcut box for QA on staging (set false before go-live)
SSU_SHOW_TEST_ACCOUNTS=true
